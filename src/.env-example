# ----- Backend (FastAPI / WebSocket) -----------------------------------

# Porta exposta no host para a API/WebSocket do backend
BACKEND_PORT=8000

# Caminho do arquivo SQLite dentro do container (persistido via volume)
DB_PATH=db/telemetria.db

# ----- Frontend (React) -------------------------------------------------

# Porta exposta no host para o dashboard (servidor de dev do CRA em modo
# desenvolvimento / Nginx em modo produção - ver docker-compose.yml e
# docker-compose.prod.yml)
FRONTEND_PORT=3000

# URL base da API REST consumida pelo frontend (precisa ser http://localhost:<BACKEND_PORT>
# pois é resolvida pelo NAVEGADOR do usuário, não por dentro da rede Docker).
REACT_APP_API_BASE=http://localhost:8000

# URL do WebSocket de telemetria, também resolvida pelo navegador.
# Usada como valor inicial; pode ser trocada na tela de Configurações do dashboard.
REACT_APP_WS_URL=ws://localhost:8000/ws/dashboard